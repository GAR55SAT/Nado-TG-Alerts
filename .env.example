# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat IDs that receive alerts (comma-separated)
TELEGRAM_CHAT_IDS=your_chat_id_here

# Nado network: mainnet | testnet
NADO_NETWORK=mainnet

# Optional default wallet (you can also use /addwallet in the bot)
NADO_WALLET_ADDRESS=
NADO_SUBACCOUNT_NAME=default

# Polling interval (seconds)
POLL_INTERVAL_SECONDS=30

# /nadofunding command: show Nado markets with |APR| >= this (annualized from 24h rate)
FUNDING_OPPORTUNITY_APR_PCT=10

# /fundingarb command: min spread vs Nado (APR %) to show an opportunity
FUNDING_ARB_MIN_SPREAD_APR_PCT=30

# Max opportunities returned by /fundingarb
FUNDING_ARB_MAX_RESULTS=8

# Warn when maintenance health falls below this USD equivalent
HEALTH_WARNING_USD=50

# Min seconds between low-health alerts (default 900 = 15 min)
HEALTH_ALERT_COOLDOWN_SECONDS=900

# Warn when account appears in liquidation feed
LIQUIDATION_FEED_ALERT=true

# Auto funding alerts (off by default — use /nadofunding or /fundingarb instead)
GLOBAL_FUNDING_ALERTS=false
PERSONAL_FUNDING_ALERTS=false

# Global liquidation feed (new accounts at risk)
GLOBAL_LIQUIDATION_ALERTS=false
